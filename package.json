{
  "name": "zavit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate",
    "dev": "next dev",
    "build": "npm run prisma:generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "npm run prisma:generate && tsc --noEmit",
    "test": "node --test \"tests/ingest/*.test.mjs\"",
    "test:evaluation": "node --test \"tests/evaluation/*.test.mjs\"",
    "test:admin": "node --test \"tests/admin/*.test.mjs\"",
    "test:reports": "node --test \"tests/reports/*.test.mjs\"",
    "validate:sources": "node ./scripts/validate-source-roster.mjs",
    "db:push": "npx prisma db push",
    "seed:sources": "node ./scripts/sync-source-roster.mjs",
    "ingest:sources": "node ./scripts/run-ingest.mjs",
    "eval:clustering": "node ./scripts/run-clustering-eval.mjs",
    "eval:clustering:repro": "node ./scripts/check-clustering-eval-repro.mjs",
    "test:events": "node --test \"tests/events/*.test.mjs\"",
    "cluster:regression": "node ./scripts/run-clustering-regression.mjs --provider deterministic",
    "events:run": "node ./scripts/run-event-pipeline.mjs",
    "events:run:deterministic": "node ./scripts/run-event-pipeline.mjs --provider deterministic"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "7.5.0",
    "dotenv": "17.2.3",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "playwright-core": "^1.58.2",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "7.5.0",
    "typescript": "^5"
  }
}
